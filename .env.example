# ── Application ──
APP_NAME=EdgeCloudProcessor
APP_VERSION=2.0.0
DEBUG=true

# ── Server ──
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000

# ── Redis ──
REDIS_URL=redis://localhost:6379/0
REDIS_STATE_DB=redis://localhost:6379/1
REDIS_CACHE_DB=redis://localhost:6379/2

# ── Auth (set AUTH_ENABLED=true for production) ──
AUTH_ENABLED=false
JWT_SECRET=change-this-in-production-to-a-random-64-char-string
JWT_EXPIRY_HOURS=24

# ── Cloud Mode ──
CLOUD_MODE=simulated
# CLOUD_MODE=real

# ── AWS (only needed if CLOUD_MODE=real) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=edgecloud-processing
AWS_EC2_INSTANCE_TYPE=t3.micro

# ── Rate Limiting ──
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# ── File Upload ──
MAX_UPLOAD_SIZE_MB=500
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs

# ── Processing ──
LOCAL_WORKER_PROCESSES=4
GPU_MEMORY_SAFETY_FACTOR=0.7
RAY_NUM_CPUS=4

# ── Energy Model (Watts) ──
CPU_TDP_W=65
GPU_TDP_W=150
CPU_IDLE_W=10
GPU_IDLE_W=15
